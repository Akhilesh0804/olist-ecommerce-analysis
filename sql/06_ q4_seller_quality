-- Q4: Underperforming seller analysis
-- Purpose: Identify sellers with sustained poor customer satisfaction
--          scores and analyse their delivery performance and geographic
--          location to determine whether underperformance is driven by
--          delivery time, product quality, or seller behaviour
-- Tables used: sellers, order_items, orders, order_reviews
-- Key decisions:
--   1. Filtered to delivered orders only (order_status = 'delivered')
--      for consistency with project methodology
--   2. Minimum threshold of 10 orders applied via HAVING clause to
--      ensure findings reflect sustained underperformance rather than
--      isolated negative experiences from low volume sellers
--   3. Satisfaction threshold set at below 3.5 average review score
--      to capture sellers with a meaningful and consistent gap below
--      the platform average of approximately 4.1
--   4. LEFT JOIN used on order_reviews to retain all delivered orders
--      in aggregation regardless of whether a review was left
--   5. Ordered by avg_review_score ascending so worst performers
--      appear first
-- Output: 78 sellers meeting threshold criteria shown here as top 10
--         worst performers by avg review score, displaying seller id,
--         city, state, total orders, avg delivery days, avg review score

WITH delivery_data AS (
    SELECT
        s.seller_id,
        s.seller_city,
        s.seller_state,
        o.order_id,
        orr.review_score,
        ROUND(DATE_PART('epoch', o.order_delivered_customer_date - o.order_purchase_timestamp)::NUMERIC / 86400, 1) AS delivery_days
    FROM sellers AS s
    LEFT JOIN order_items AS oi
        ON s.seller_id = oi.seller_id
    LEFT JOIN orders AS o
        ON oi.order_id = o.order_id
    LEFT JOIN order_reviews AS orr
        ON o.order_id = orr.order_id
    WHERE o.order_status = 'delivered'
)
SELECT
    seller_id,
    seller_city,
    seller_state,
    COUNT(DISTINCT order_id)        AS total_orders,
    ROUND(AVG(delivery_days), 1)    AS avg_delivery_days,
    ROUND(AVG(review_score), 2)     AS avg_review_score
FROM delivery_data
GROUP BY seller_id, seller_city, seller_state
HAVING COUNT(DISTINCT order_id) >= 10
    AND ROUND(AVG(review_score), 2) < 3.5
ORDER BY avg_review_score
LIMIT 10 ;
