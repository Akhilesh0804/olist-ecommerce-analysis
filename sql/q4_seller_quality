WITH delivery_data AS (
    SELECT
        s.seller_id,
        s.seller_city,
        s.seller_state,
        o.order_id,
        orr.review_score,
        ROUND(DATE_PART('epoch', o.order_delivered_customer_date - o.order_purchase_timestamp)::NUMERIC / 86400, 1) AS delivery_days
    FROM sellers AS s
    LEFT JOIN order_items AS oi
        ON s.seller_id = oi.seller_id
    LEFT JOIN orders AS o
        ON oi.order_id = o.order_id
    LEFT JOIN order_reviews AS orr
        ON o.order_id = orr.order_id
    WHERE o.order_status = 'delivered'
)
SELECT
    seller_id,
    seller_city,
    seller_state,
    COUNT(DISTINCT order_id)        AS total_orders,
    ROUND(AVG(delivery_days), 1)    AS avg_delivery_days,
    ROUND(AVG(review_score), 2)     AS avg_review_score
FROM delivery_data
GROUP BY seller_id, seller_city, seller_state
HAVING COUNT(DISTINCT order_id) >= 10
    AND ROUND(AVG(review_score), 2) < 3.5
ORDER BY avg_review_score
LIMIT 10 ;
